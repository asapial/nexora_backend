enum NimbiMessageRole {
  USER
  ASSISTANT
}

enum NimbiActionStatus {
  PENDING
  COMPLETED
  FAILED
}

model NimbiConversation {
  id            String    @id @default(uuid())
  userId        String
  roleSnapshot  Role
  title         String    @default("New conversation")
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   NimbiMessage[]
  executions NimbiActionExecution[]

  @@index([userId, updatedAt])
  @@map("nimbi_conversation")
}

model NimbiMessage {
  id             String           @id @default(uuid())
  conversationId String
  role           NimbiMessageRole
  content        String           @db.Text
  metadata       Json?
  createdAt      DateTime         @default(now())

  conversation NimbiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  executions   NimbiActionExecution[]

  @@index([conversationId, createdAt])
  @@map("nimbi_message")
}

model NimbiActionExecution {
  id              String           @id @default(uuid())
  userId          String
  conversationId   String?
  messageId        String?
  actionKey        String
  idempotencyKey   String           @unique
  input            Json
  result           Json?
  status           NimbiActionStatus @default(PENDING)
  confirmedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation NimbiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message      NimbiMessage?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@map("nimbi_action_execution")
}
