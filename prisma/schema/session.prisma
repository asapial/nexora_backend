 
model SessionFeedback {
  id          String    @id @default(uuid())
  sessionId   String
  memberId    String
  rating      Int       // 1-5
  comment     String?
  submittedAt DateTime  @default(now())
 
  session     Session   @relation(fields: [sessionId], references: [id])
 
  @@unique([sessionId, memberId])
}
 

model SessionAgenda {
  id          String    @id @default(uuid())
  sessionId   String
  startTime   String
  topic       String
  presenter   String?
  order       Int       @default(0)
 
  session     Session   @relation(fields: [sessionId], references: [id])
}