 
model MemberGoal {
  id          String    @id @default(uuid())
  userId      String
  clusterId   String
  title       String
  target      String?
  isAchieved  Boolean   @default(false)
  achievedAt  DateTime?
  createdAt   DateTime  @default(now())
 
  user        User      @relation(fields: [userId], references: [id])
}