<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="x-apple-disable-message-reformatting" />
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no" />
  <title>Verify Your Email — Nexora</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style>
    /* ── RESET ───────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; }
    body { margin: 0 !important; padding: 0 !important; width: 100% !important; }

    /* ── NEXORA TOKENS ───────────────────────────── */
    /* bg: #09090b  card: #111113  border: #27272a
       teal-600: #0d9488  teal-400: #2dd4bf  teal-300: #5eead4
       zinc-400: #a1a1aa  zinc-500: #71717a  zinc-600: #52525b */

    body { background-color: #09090b; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; }

    .wrapper  { width: 100%; background-color: #09090b; padding: 48px 16px; }
    .container { max-width: 560px; margin: 0 auto; background-color: #111113; border: 1px solid #27272a; border-radius: 16px; overflow: hidden; }

    /* ── TEAL TOP BAR ────────────────────────────── */
    .top-bar { height: 3px; background: linear-gradient(90deg, transparent 0%, #0d9488 25%, #14b8a6 55%, #2dd4bf 80%, transparent 100%); }

    /* ── HEADER ──────────────────────────────────── */
    .header { padding: 36px 48px 28px; text-align: center; border-bottom: 1px solid #27272a; }
    .logo-wrap { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-hex  { display: inline-block; width: 36px; height: 36px; background: rgba(20,184,166,.12); border: 1px solid rgba(20,184,166,.25); border-radius: 9px; font-size: 18px; line-height: 36px; text-align: center; color: #2dd4bf; }
    .logo-name { font-size: 20px; font-weight: 800; letter-spacing: -0.025em; color: #fafafa; text-decoration: none; }
    .logo-tag  { display: block; margin-top: 7px; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #52525b; font-family: 'Courier New', monospace; }

    /* ── BODY ────────────────────────────────────── */
    .body { padding: 40px 48px; }
    .greeting { font-size: 21px; font-weight: 700; color: #fafafa; margin: 0 0 12px; line-height: 1.3; }
    .intro    { font-size: 14.5px; color: #71717a; line-height: 1.8; margin: 0 0 32px; }
    .intro strong { color: #a1a1aa; }

    /* ── OTP BLOCK ───────────────────────────────── */
    .otp-label { display: block; font-size: 10.5px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #52525b; font-family: 'Courier New', monospace; margin: 0 0 12px; }

    .otp-card {
      position: relative;
      background-color: #18181b;
      border: 1px solid #27272a;
      border-radius: 14px;
      padding: 32px 24px 26px;
      text-align: center;
      margin-bottom: 10px;
      overflow: hidden;
    }
    /* teal shimmer top edge */
    .otp-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, #0d9488 40%, #2dd4bf 60%, transparent);
    }
    /* subtle radial glow */
    .otp-card::after {
      content: '';
      position: absolute;
      top: -20px; left: 50%;
      transform: translateX(-50%);
      width: 220px; height: 80px;
      background: radial-gradient(ellipse, rgba(20,184,166,.1) 0%, transparent 70%);
      pointer-events: none;
    }

    .otp-digits {
      display: block;
      font-family: 'Courier New', Courier, monospace;
      font-size: 48px;
      font-weight: 800;
      letter-spacing: 0.26em;
      color: #2dd4bf;
      line-height: 1;
      position: relative;
      z-index: 1;
    }
    .otp-meta {
      margin: 14px 0 0;
      font-size: 12px;
      color: #52525b;
      font-family: 'Courier New', monospace;
      letter-spacing: 0.06em;
      position: relative;
      z-index: 1;
    }
    .otp-meta strong { color: #71717a; }

    /* ── DIVIDER ─────────────────────────────────── */
    .divider { border: none; border-top: 1px solid #27272a; margin: 32px 0; }

    /* ── INFO ROWS ───────────────────────────────── */
    .info-icon {
      width: 36px; height: 36px;
      background-color: #18181b;
      border: 1px solid #27272a;
      border-radius: 8px;
      font-size: 16px;
      line-height: 36px;
      text-align: center;
      display: inline-block;
    }
    .info-title { font-size: 13px; font-weight: 600; color: #a1a1aa; margin: 0 0 2px; }
    .info-desc  { font-size: 13px; color: #52525b; margin: 0; line-height: 1.6; }
    .info-desc .hl { color: #2dd4bf; }

    /* ── WARNING ─────────────────────────────────── */
    .warning {
      background-color: #1a1209;
      border: 1px solid #3a2a10;
      border-left: 3px solid #f59e0b;
      border-radius: 8px;
      padding: 14px 18px;
      margin-top: 28px;
    }
    .warning p { font-size: 13px; color: #78716c; margin: 0; line-height: 1.7; }
    .warning p strong { color: #f59e0b; }

    /* ── FOOTER ──────────────────────────────────── */
    .footer { padding: 22px 48px 32px; border-top: 1px solid #27272a; text-align: center; }
    .footer-text  { font-size: 12px; color: #3f3f46; line-height: 1.8; margin: 0 0 6px; }
    .footer-text a { color: #3f3f46; text-decoration: none; }
    .footer-text a:hover { color: #71717a; }
    .footer-sep   { display: inline-block; margin: 0 8px; color: #27272a; }
    .footer-brand { font-size: 10.5px; color: #27272a; letter-spacing: 0.16em; font-family: 'Courier New', monospace; margin: 14px 0 0; }

    @media only screen and (max-width: 600px) {
      .header, .body, .footer { padding-left: 28px !important; padding-right: 28px !important; }
      .otp-digits { font-size: 36px !important; letter-spacing: 0.18em !important; }
      .greeting   { font-size: 19px !important; }
    }
  </style>
</head>
<body>
<div class="wrapper">
  <div class="container">

    <!-- TEAL TOP BAR -->
    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">
      <a class="logo-wrap" href="#" style="text-decoration:none;display:inline-block;">
        <span class="logo-hex">⬡</span>
        <span class="logo-name">Nexora</span>
      </a>
      <span class="logo-tag">Where Knowledge Meets Mentorship</span>
    </div>

    <!-- BODY -->
    <div class="body">

      <h1 class="greeting">Verify your email, <%= name %></h1>

      <p class="intro">
        Welcome to <strong>Nexora</strong>. To complete your registration,
        enter the one-time verification code below on the verification screen.
        It confirms you own this email address.
      </p>

      <!-- OTP -->
      <span class="otp-label">Your verification code</span>
      <div class="otp-card">
        <span class="otp-digits"><%= otp %></span>
        <p class="otp-meta">
          &#x23F1;&nbsp; Expires in <strong><%= expiresIn || '10 minutes' %></strong>
          &nbsp;&bull;&nbsp; One-time use only
        </p>
      </div>

      <hr class="divider" />

      <!-- INFO ROWS -->
      <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
        <tr><td style="padding-bottom:16px;">
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
            <td width="46" valign="top"><div class="info-icon">&#128274;</div></td>
            <td style="padding-left:14px;padding-top:4px;">
              <p class="info-title">Single use only</p>
              <p class="info-desc">This code is invalidated immediately after use. Request a new one if needed.</p>
            </td>
          </tr></table>
        </td></tr>

        <tr><td style="padding-bottom:16px;">
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
            <td width="46" valign="top"><div class="info-icon">&#128336;</div></td>
            <td style="padding-left:14px;padding-top:4px;">
              <p class="info-title">Code expires in <%= expiresIn || '10 minutes' %></p>
              <p class="info-desc">Return to the Nexora verification page and enter the code before it expires.</p>
            </td>
          </tr></table>
        </td></tr>

        <tr><td>
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
            <td width="46" valign="top"><div class="info-icon">&#128100;</div></td>
            <td style="padding-left:14px;padding-top:4px;">
              <p class="info-title">Registering as <span style="color:#2dd4bf;"><%= name %></span></p>
              <p class="info-desc">Verifying <span class="hl"><%= email %></span>. Not you? Ignore this email safely.</p>
            </td>
          </tr></table>
        </td></tr>
      </table>

      <!-- WARNING -->
      <div class="warning">
        <p><strong>&#9888;&nbsp; Never share this code</strong> &mdash;
        Nexora will never ask for your verification code by phone, chat, or any other channel.
        If you did not create a Nexora account, no action is required.</p>
      </div>

    </div><!-- /body -->

    <!-- FOOTER -->
    <div class="footer">
      <p class="footer-text">This is an automated message from Nexora. Please do not reply.</p>
      <p class="footer-text">
        <a href="#">Privacy Policy</a>
        <span class="footer-sep">&bull;</span>
        <a href="#">Terms of Service</a>
        <span class="footer-sep">&bull;</span>
        <a href="#">Help Centre</a>
      </p>
      <p class="footer-brand">NEXORA &nbsp;&bull;&nbsp; WHERE KNOWLEDGE MEETS MENTORSHIP</p>
    </div>

  </div><!-- /container -->
</div><!-- /wrapper -->
</body>
</html>
