<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="x-apple-disable-message-reformatting" />
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no" />
  <title>Reset Your Password — Nexora</title>

  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->

  <style>
    /* ── RESET ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; }
    body { margin: 0 !important; padding: 0 !important; width: 100% !important; }

    /* ── BASE ──────────────────────────────────────────── */
    body {
      background-color: #f0f2f5;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
                   'Helvetica Neue', Arial, sans-serif;
    }

    .email-wrapper {
      width: 100%;
      background-color: #f0f2f5;
      padding: 48px 16px;
    }

    .email-container {
      max-width: 560px;
      margin: 0 auto;
      background-color: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.07), 0 1px 4px rgba(0,0,0,0.04);
    }

    /* ── HEADER ────────────────────────────────────────── */
    .email-header {
      background-color: #ffffff;
      padding: 32px 48px 26px;
      text-align: center;
      border-bottom: 1px solid #f3f4f6;
    }

    .logo-text {
      font-size: 26px;
      font-weight: 800;
      letter-spacing: -0.04em;
      color: #111827;
      text-decoration: none;
    }

    .logo-dot { color: #2563eb; }

    .logo-tag {
      display: block;
      margin-top: 5px;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #9ca3af;
    }

    /* ── HERO ──────────────────────────────────────────── */
    .hero-section {
      background: linear-gradient(155deg, #eff6ff 0%, #f8f9ff 55%, #faf5ff 100%);
      padding: 44px 48px 36px;
      text-align: center;
      border-bottom: 1px solid #e8edf5;
    }

    .icon-outer {
      display: inline-block;
      width: 72px;
      height: 72px;
      background: linear-gradient(135deg, #dbeafe 0%, #ede9fe 100%);
      border-radius: 50%;
      position: relative;
      margin-bottom: 22px;
    }

    .icon-inner {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 42px;
      height: 42px;
      background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
      border-radius: 50%;
      font-size: 19px;
      line-height: 42px;
      text-align: center;
    }

    .hero-title {
      font-size: 23px;
      font-weight: 700;
      color: #111827;
      margin: 0 0 10px;
      letter-spacing: -0.02em;
      line-height: 1.3;
    }

    .hero-sub {
      font-size: 15px;
      color: #6b7280;
      margin: 0;
      line-height: 1.75;
    }

    .hero-sub strong { color: #374151; font-weight: 600; }

    /* ── BODY ──────────────────────────────────────────── */
    .email-body {
      padding: 36px 48px 40px;
      background-color: #ffffff;
    }

    /* ── OTP ───────────────────────────────────────────── */
    .otp-label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #9ca3af;
      text-align: center;
      margin-bottom: 14px;
    }

    .otp-card {
      background: linear-gradient(145deg, #f8faff 0%, #faf5ff 100%);
      border: 1.5px solid #e0e7ff;
      border-radius: 14px;
      padding: 30px 24px 22px;
      text-align: center;
      margin-bottom: 10px;
      position: relative;
      overflow: hidden;
    }

    .otp-card::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 2px;
      background: linear-gradient(90deg, transparent, #2563eb, #7c3aed, transparent);
      border-radius: 0 0 4px 4px;
    }

    .otp-digits {
      font-family: 'Courier New', Courier, monospace;
      font-size: 46px;
      font-weight: 800;
      letter-spacing: 0.28em;
      color: #2563eb;
      line-height: 1;
      display: block;
    }

    .otp-meta {
      margin-top: 14px;
      font-size: 12.5px;
      color: #9ca3af;
    }

    .otp-meta strong { color: #6b7280; }

    .pill {
      display: inline-block;
      background-color: #fef3c7;
      color: #92400e;
      font-size: 11px;
      font-weight: 600;
      padding: 2px 10px;
      border-radius: 999px;
      margin-left: 6px;
      vertical-align: middle;
    }

    /* ── DIVIDER ───────────────────────────────────────── */
    .divider {
      border: none;
      border-top: 1px solid #f3f4f6;
      margin: 32px 0;
    }

    /* ── STEPS ─────────────────────────────────────────── */
    .section-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #9ca3af;
      margin: 0 0 20px;
    }

    .step-num {
      width: 28px;
      height: 28px;
      background: linear-gradient(135deg, #eff6ff, #ede9fe);
      border: 1px solid #ddd6fe;
      border-radius: 50%;
      font-size: 12px;
      font-weight: 700;
      color: #4f46e5;
      line-height: 28px;
      text-align: center;
    }

    .step-title {
      font-size: 14px;
      font-weight: 600;
      color: #111827;
      margin: 0 0 3px;
    }

    .step-desc {
      font-size: 13px;
      color: #9ca3af;
      margin: 0;
      line-height: 1.6;
    }

    .step-desc strong { color: #374151; }

    /* ── INFO CHIPS ────────────────────────────────────── */
    .chip {
      background-color: #f9fafb;
      border: 1px solid #f3f4f6;
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 10px;
    }

    .chip-icon {
      width: 34px;
      height: 34px;
      border-radius: 8px;
      font-size: 15px;
      line-height: 34px;
      text-align: center;
    }

    .bg-blue   { background-color: #eff6ff; }
    .bg-purple { background-color: #f5f3ff; }
    .bg-green  { background-color: #f0fdf4; }

    .chip-title {
      font-size: 13px;
      font-weight: 600;
      color: #374151;
      margin: 0 0 2px;
    }

    .chip-desc {
      font-size: 12.5px;
      color: #9ca3af;
      margin: 0;
      line-height: 1.5;
    }

    .hl { color: #2563eb; font-weight: 500; }

    /* ── SECURITY NOTE ─────────────────────────────────── */
    .security-note {
      background-color: #fffbeb;
      border: 1px solid #fde68a;
      border-left: 3px solid #f59e0b;
      border-radius: 8px;
      padding: 14px 16px;
      margin-top: 26px;
    }

    .security-note p {
      font-size: 13px;
      color: #92400e;
      margin: 0;
      line-height: 1.75;
    }

    .security-note strong { color: #b45309; }

    /* ── NO REQUEST ────────────────────────────────────── */
    .no-request {
      background-color: #f9fafb;
      border: 1px solid #f3f4f6;
      border-radius: 8px;
      padding: 14px 18px;
      margin-top: 12px;
      text-align: center;
    }

    .no-request p {
      font-size: 13px;
      color: #9ca3af;
      margin: 0;
      line-height: 1.75;
    }

    .no-request strong { color: #6b7280; }

    /* ── FOOTER ────────────────────────────────────────── */
    .email-footer {
      background-color: #f9fafb;
      padding: 24px 48px 32px;
      border-top: 1px solid #f0f0f0;
      text-align: center;
    }

    .footer-text {
      font-size: 12px;
      color: #d1d5db;
      line-height: 1.8;
      margin: 0 0 6px;
    }

    .footer-text a { color: #9ca3af; text-decoration: none; }

    .sep { display: inline-block; margin: 0 8px; color: #e5e7eb; }

    .footer-brand {
      font-size: 11px;
      color: #d1d5db;
      letter-spacing: 0.14em;
      margin: 14px 0 0;
    }

    /* ── RESPONSIVE ────────────────────────────────────── */
    @media only screen and (max-width: 600px) {
      .email-header,
      .hero-section,
      .email-body,
      .email-footer { padding-left: 28px !important; padding-right: 28px !important; }
      .otp-digits   { font-size: 36px !important; letter-spacing: 0.2em !important; }
      .hero-title   { font-size: 20px !important; }
    }
  </style>
</head>

<body>
  <div class="email-wrapper">
    <div class="email-container">

      <!-- ── HEADER ─────────────────────────────────────── -->
      <div class="email-header">
        <a class="logo-text" href="#" style="text-decoration:none;">
          Nex<span class="logo-dot">o</span>ra
        </a>
        <span class="logo-tag">Where Knowledge Meets Mentorship</span>
      </div>

      <!-- ── HERO ───────────────────────────────────────── -->
      <div class="hero-section">
        <div class="icon-outer">
          <div class="icon-inner">&#128274;</div>
        </div>
        <h1 class="hero-title">Password Reset Request</h1>
        <p class="hero-sub">
          Hi <strong><%= name %></strong>, we received a request to reset the
          password for your Nexora account linked to
          <strong><%= email %></strong>.
        </p>
      </div>

      <!-- ── BODY ───────────────────────────────────────── -->
      <div class="email-body">

        <!-- OTP -->
        <span class="otp-label">Your one-time reset code</span>
        <div class="otp-card">
          <span class="otp-digits"><%= otp %></span>
          <p class="otp-meta">
            Expires in <strong><%= expiresIn || '10 minutes' %></strong>
            <span class="pill">One-time use</span>
          </p>
        </div>

        <hr class="divider" />

        <!-- STEPS -->
        <p class="section-label">How to reset your password</p>

        <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
          <tr>
            <td style="padding-bottom:16px;">
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                <tr>
                  <td width="40" valign="top"><div class="step-num">1</div></td>
                  <td style="padding-left:14px; padding-top:2px;">
                    <p class="step-title">Copy the code above</p>
                    <p class="step-desc">Return to the Nexora password reset page and paste the code in the verification field.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding-bottom:16px;">
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                <tr>
                  <td width="40" valign="top"><div class="step-num">2</div></td>
                  <td style="padding-left:14px; padding-top:2px;">
                    <p class="step-title">Enter it before it expires</p>
                    <p class="step-desc">The code is valid for <strong><%= expiresIn || '10 minutes' %></strong>. You can request a new one from the login page if needed.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td>
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                <tr>
                  <td width="40" valign="top"><div class="step-num">3</div></td>
                  <td style="padding-left:14px; padding-top:2px;">
                    <p class="step-title">Set your new password</p>
                    <p class="step-desc">Choose a strong, unique password and you are all set to continue on Nexora.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>

        <hr class="divider" />

        <!-- INFO CHIPS -->
        <div class="chip">
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
            <tr>
              <td width="46" valign="middle"><div class="chip-icon bg-blue">&#128336;</div></td>
              <td style="padding-left:12px;">
                <p class="chip-title">Expires in <%= expiresIn || '10 minutes' %></p>
                <p class="chip-desc">Time-sensitive — request a new code from the login page if it expires.</p>
              </td>
            </tr>
          </table>
        </div>

        <div class="chip">
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
            <tr>
              <td width="46" valign="middle"><div class="chip-icon bg-purple">&#128100;</div></td>
              <td style="padding-left:12px;">
                <p class="chip-title">Account: <span class="hl"><%= name %></span></p>
                <p class="chip-desc">Reset requested for <span class="hl"><%= email %></span>. Only this account is affected.</p>
              </td>
            </tr>
          </table>
        </div>

        <div class="chip">
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
            <tr>
              <td width="46" valign="middle"><div class="chip-icon bg-green">&#9989;</div></td>
              <td style="padding-left:12px;">
                <p class="chip-title">Single use only</p>
                <p class="chip-desc">This code is immediately invalidated once used or once it expires.</p>
              </td>
            </tr>
          </table>
        </div>

        <!-- SECURITY NOTE -->
        <div class="security-note">
          <p>
            <strong>&#9888;&nbsp; Never share this code</strong> &mdash;
            Nexora will never ask for your reset code via phone, chat, or any
            other channel. If you did not request a password reset, your account
            remains safe &mdash; simply ignore this email.
          </p>
        </div>

        <!-- DID NOT REQUEST -->
        <div class="no-request">
          <p>
            Didn&rsquo;t request this reset?&nbsp;
            <strong>No action is needed.</strong>
            Your password has <strong>not</strong> been changed and your
            account remains fully secure.
          </p>
        </div>

      </div><!-- /email-body -->

      <!-- ── FOOTER ─────────────────────────────────────── -->
      <div class="email-footer">
        <p class="footer-text">
          This is an automated message from Nexora &mdash; please do not reply.
        </p>
        <p class="footer-text">
          <a href="#">Privacy Policy</a>
          <span class="sep">&bull;</span>
          <a href="#">Terms of Service</a>
          <span class="sep">&bull;</span>
          <a href="#">Help Centre</a>
        </p>
        <p class="footer-brand">NEXORA &nbsp;&bull;&nbsp; WHERE KNOWLEDGE MEETS MENTORSHIP</p>
      </div>

    </div><!-- /email-container -->
  </div><!-- /email-wrapper -->
</body>
</html>
