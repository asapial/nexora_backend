<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="x-apple-disable-message-reformatting" />
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no" />
  <title>Reset Your Password — Nexora</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; }
    body { margin: 0 !important; padding: 0 !important; width: 100% !important; }

    body { background-color: #09090b; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; }

    .wrapper   { width: 100%; background-color: #09090b; padding: 48px 16px; }
    .container { max-width: 560px; margin: 0 auto; background-color: #111113; border: 1px solid #27272a; border-radius: 16px; overflow: hidden; }

    .top-bar { height: 3px; background: linear-gradient(90deg, transparent 0%, #0d9488 25%, #14b8a6 55%, #2dd4bf 80%, transparent 100%); }

    /* HEADER */
    .header { padding: 36px 48px 28px; text-align: center; border-bottom: 1px solid #27272a; }
    .logo-hex  { display: inline-block; width: 36px; height: 36px; background: rgba(20,184,166,.12); border: 1px solid rgba(20,184,166,.25); border-radius: 9px; font-size: 18px; line-height: 36px; text-align: center; color: #2dd4bf; vertical-align: middle; }
    .logo-name { font-size: 20px; font-weight: 800; letter-spacing: -0.025em; color: #fafafa; vertical-align: middle; margin-left: 10px; }
    .logo-tag  { display: block; margin-top: 7px; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #52525b; font-family: 'Courier New', monospace; }

    /* HERO STRIP */
    .hero {
      padding: 36px 48px 30px;
      text-align: center;
      border-bottom: 1px solid #27272a;
      background-color: #0d1117;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -40px; left: 50%;
      transform: translateX(-50%);
      width: 300px; height: 120px;
      background: radial-gradient(ellipse, rgba(20,184,166,.08) 0%, transparent 70%);
    }
    .hero-icon-wrap {
      display: inline-block;
      width: 68px; height: 68px;
      background: rgba(20,184,166,.1);
      border: 1px solid rgba(20,184,166,.22);
      border-radius: 18px;
      font-size: 28px;
      line-height: 68px;
      text-align: center;
      margin-bottom: 20px;
      position: relative;
      z-index: 1;
    }
    .hero-title { font-size: 21px; font-weight: 700; color: #fafafa; margin: 0 0 10px; letter-spacing: -0.02em; line-height: 1.3; position: relative; z-index: 1; }
    .hero-sub   { font-size: 14.5px; color: #71717a; margin: 0; line-height: 1.75; position: relative; z-index: 1; }
    .hero-sub strong { color: #a1a1aa; }

    /* BODY */
    .body { padding: 36px 48px 40px; }

    /* OTP */
    .otp-label { display: block; font-size: 10.5px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #52525b; font-family: 'Courier New', monospace; margin: 0 0 12px; text-align: center; }

    .otp-card {
      position: relative;
      background-color: #18181b;
      border: 1px solid #27272a;
      border-radius: 14px;
      padding: 32px 24px 24px;
      text-align: center;
      margin-bottom: 10px;
      overflow: hidden;
    }
    .otp-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, #0d9488 40%, #2dd4bf 60%, transparent);
    }
    .otp-card::after {
      content: '';
      position: absolute;
      top: -20px; left: 50%;
      transform: translateX(-50%);
      width: 220px; height: 80px;
      background: radial-gradient(ellipse, rgba(20,184,166,.09) 0%, transparent 70%);
      pointer-events: none;
    }
    .otp-digits {
      display: block;
      font-family: 'Courier New', Courier, monospace;
      font-size: 48px; font-weight: 800;
      letter-spacing: 0.26em;
      color: #2dd4bf;
      line-height: 1;
      position: relative; z-index: 1;
    }
    .otp-meta {
      margin: 14px 0 0;
      font-size: 12px; color: #52525b;
      font-family: 'Courier New', monospace;
      letter-spacing: 0.06em;
      position: relative; z-index: 1;
    }
    .otp-meta strong { color: #71717a; }
    .otp-badge {
      display: inline-block;
      background-color: #1a1209;
      color: #f59e0b;
      border: 1px solid #3a2a10;
      font-size: 10.5px; font-weight: 700;
      padding: 2px 9px; border-radius: 999px;
      margin-left: 6px; vertical-align: middle;
      font-family: sans-serif; letter-spacing: 0;
    }

    /* DIVIDER */
    .divider { border: none; border-top: 1px solid #27272a; margin: 30px 0; }

    /* STEPS */
    .section-label { font-size: 10.5px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #52525b; margin: 0 0 18px; font-family: 'Courier New', monospace; display: block; }
    .step-num {
      width: 28px; height: 28px;
      background: rgba(20,184,166,.1);
      border: 1px solid rgba(20,184,166,.2);
      border-radius: 50%;
      font-size: 12px; font-weight: 700;
      color: #14b8a6;
      line-height: 28px; text-align: center;
      display: inline-block;
    }
    .step-title { font-size: 13.5px; font-weight: 600; color: #a1a1aa; margin: 0 0 3px; }
    .step-desc  { font-size: 13px; color: #52525b; margin: 0; line-height: 1.6; }
    .step-desc strong { color: #71717a; }

    /* INFO CHIPS */
    .chip {
      background-color: #18181b;
      border: 1px solid #27272a;
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 10px;
    }
    .chip-icon {
      width: 34px; height: 34px;
      background: rgba(20,184,166,.1);
      border: 1px solid rgba(20,184,166,.18);
      border-radius: 8px;
      font-size: 15px; line-height: 34px;
      text-align: center; display: inline-block;
    }
    .chip-title { font-size: 13px; font-weight: 600; color: #a1a1aa; margin: 0 0 2px; }
    .chip-desc  { font-size: 12.5px; color: #52525b; margin: 0; line-height: 1.5; }
    .chip-desc .hl { color: #2dd4bf; }

    /* SECURITY */
    .security {
      background-color: #1a1209;
      border: 1px solid #3a2a10;
      border-left: 3px solid #f59e0b;
      border-radius: 8px;
      padding: 14px 18px;
      margin-top: 24px;
    }
    .security p { font-size: 13px; color: #78716c; margin: 0; line-height: 1.7; }
    .security p strong { color: #f59e0b; }

    .no-request {
      background-color: #18181b;
      border: 1px solid #27272a;
      border-radius: 8px;
      padding: 14px 18px;
      margin-top: 10px;
      text-align: center;
    }
    .no-request p { font-size: 13px; color: #52525b; margin: 0; line-height: 1.75; }
    .no-request p strong { color: #71717a; }

    /* FOOTER */
    .footer { padding: 22px 48px 32px; border-top: 1px solid #27272a; text-align: center; }
    .footer-text  { font-size: 12px; color: #3f3f46; line-height: 1.8; margin: 0 0 6px; }
    .footer-text a { color: #3f3f46; text-decoration: none; }
    .footer-sep   { display: inline-block; margin: 0 8px; color: #27272a; }
    .footer-brand { font-size: 10.5px; color: #27272a; letter-spacing: 0.16em; font-family: 'Courier New', monospace; margin: 14px 0 0; }

    @media only screen and (max-width: 600px) {
      .header, .hero, .body, .footer { padding-left: 28px !important; padding-right: 28px !important; }
      .otp-digits { font-size: 36px !important; letter-spacing: 0.18em !important; }
      .hero-title { font-size: 19px !important; }
    }
  </style>
</head>
<body>
<div class="wrapper">
  <div class="container">

    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">
      <a href="#" style="text-decoration:none;">
        <span class="logo-hex">⬡</span><span class="logo-name">Nexora</span>
      </a>
      <span class="logo-tag">Where Knowledge Meets Mentorship</span>
    </div>

    <!-- HERO -->
    <div class="hero">
      <div class="hero-icon-wrap">&#128274;</div>
      <h1 class="hero-title">Password Reset Request</h1>
      <p class="hero-sub">
        Hi <strong><%= name %></strong>, we received a request to reset the password
        for your Nexora account linked to <strong><%= email %></strong>.
      </p>
    </div>

    <!-- BODY -->
    <div class="body">

      <span class="otp-label">Your one-time reset code</span>
      <div class="otp-card">
        <span class="otp-digits"><%= otp %></span>
        <p class="otp-meta">
          Expires in <strong><%= expiresIn || '10 minutes' %></strong>
          <span class="otp-badge">One-time use</span>
        </p>
      </div>

      <hr class="divider" />

      <!-- STEPS -->
      <span class="section-label">How to reset your password</span>
      <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
        <tr><td style="padding-bottom:14px;">
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
            <td width="40" valign="top"><div class="step-num">1</div></td>
            <td style="padding-left:14px;padding-top:2px;">
              <p class="step-title">Copy the code above</p>
              <p class="step-desc">Return to the Nexora password reset page and paste it in the verification field.</p>
            </td>
          </tr></table>
        </td></tr>
        <tr><td style="padding-bottom:14px;">
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
            <td width="40" valign="top"><div class="step-num">2</div></td>
            <td style="padding-left:14px;padding-top:2px;">
              <p class="step-title">Enter it before it expires</p>
              <p class="step-desc">Valid for <strong><%= expiresIn || '10 minutes' %></strong>. Request a fresh code from the login page if needed.</p>
            </td>
          </tr></table>
        </td></tr>
        <tr><td>
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
            <td width="40" valign="top"><div class="step-num">3</div></td>
            <td style="padding-left:14px;padding-top:2px;">
              <p class="step-title">Set your new password</p>
              <p class="step-desc">Choose a strong, unique password and you're all set to continue on Nexora.</p>
            </td>
          </tr></table>
        </td></tr>
      </table>

      <hr class="divider" />

      <!-- CHIPS -->
      <div class="chip">
        <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
          <td width="46" valign="middle"><div class="chip-icon">&#128336;</div></td>
          <td style="padding-left:12px;">
            <p class="chip-title">Expires in <%= expiresIn || '10 minutes' %></p>
            <p class="chip-desc">Time-sensitive — request a new code from the login page if it expires.</p>
          </td>
        </tr></table>
      </div>
      <div class="chip">
        <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
          <td width="46" valign="middle"><div class="chip-icon">&#128100;</div></td>
          <td style="padding-left:12px;">
            <p class="chip-title">Account: <span style="color:#2dd4bf;"><%= name %></span></p>
            <p class="chip-desc">Reset requested for <span class="hl"><%= email %></span>. Only this account is affected.</p>
          </td>
        </tr></table>
      </div>
      <div class="chip">
        <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
          <td width="46" valign="middle"><div class="chip-icon">&#9989;</div></td>
          <td style="padding-left:12px;">
            <p class="chip-title">Single use only</p>
            <p class="chip-desc">This code is immediately invalidated once used or once it expires.</p>
          </td>
        </tr></table>
      </div>

      <!-- SECURITY -->
      <div class="security">
        <p><strong>&#9888;&nbsp; Never share this code</strong> &mdash;
        Nexora will never ask for your reset code via phone, chat, or any other channel.
        If you did not request a password reset, your account remains safe — simply ignore this email.</p>
      </div>
      <div class="no-request">
        <p>Didn&rsquo;t request this reset?&nbsp;
        <strong>No action is needed.</strong>
        Your password has <strong>not</strong> been changed and your account remains fully secure.</p>
      </div>

    </div><!-- /body -->

    <!-- FOOTER -->
    <div class="footer">
      <p class="footer-text">This is an automated message from Nexora — please do not reply.</p>
      <p class="footer-text">
        <a href="#">Privacy Policy</a>
        <span class="footer-sep">&bull;</span>
        <a href="#">Terms of Service</a>
        <span class="footer-sep">&bull;</span>
        <a href="#">Help Centre</a>
      </p>
      <p class="footer-brand">NEXORA &nbsp;&bull;&nbsp; WHERE KNOWLEDGE MEETS MENTORSHIP</p>
    </div>

  </div>
</div>
</body>
</html>
