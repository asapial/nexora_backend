<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="x-apple-disable-message-reformatting" />
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no" />
  <title>New Cluster — Nexora</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; }
    body { margin: 0 !important; padding: 0 !important; width: 100% !important; }

    body { background-color: #09090b; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; }

    .wrapper   { width: 100%; background-color: #09090b; padding: 48px 16px; }
    .container { max-width: 560px; margin: 0 auto; background-color: #111113; border: 1px solid #27272a; border-radius: 16px; overflow: hidden; }

    .top-bar { height: 3px; background: linear-gradient(90deg, transparent 0%, #0d9488 25%, #14b8a6 55%, #2dd4bf 80%, transparent 100%); }

    /* HEADER */
    .header { padding: 36px 48px 28px; text-align: center; border-bottom: 1px solid #27272a; }
    .logo-hex  { display: inline-block; width: 36px; height: 36px; background: rgba(20,184,166,.12); border: 1px solid rgba(20,184,166,.25); border-radius: 9px; font-size: 18px; line-height: 36px; text-align: center; color: #2dd4bf; vertical-align: middle; }
    .logo-name { font-size: 20px; font-weight: 800; letter-spacing: -0.025em; color: #fafafa; vertical-align: middle; margin-left: 10px; }
    .logo-tag  { display: block; margin-top: 7px; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #52525b; font-family: 'Courier New', monospace; }

    /* HERO */
    .hero {
      padding: 36px 48px 30px;
      text-align: center;
      border-bottom: 1px solid #27272a;
      background-color: #0d1117;
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -40px; left: 50%;
      transform: translateX(-50%);
      width: 300px; height: 120px;
      background: radial-gradient(ellipse, rgba(20,184,166,.08) 0%, transparent 70%);
    }
    .hero-badge {
      display: inline-block;
      background: rgba(20,184,166,.1);
      border: 1px solid rgba(20,184,166,.22);
      color: #2dd4bf;
      font-size: 10.5px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      padding: 5px 14px; border-radius: 999px;
      margin-bottom: 18px;
      position: relative; z-index: 1;
      font-family: 'Courier New', monospace;
    }
    .hero-title { font-size: 22px; font-weight: 700; color: #fafafa; margin: 0 0 10px; letter-spacing: -0.02em; position: relative; z-index: 1; }
    .hero-sub   { font-size: 14.5px; color: #71717a; margin: 0; line-height: 1.75; position: relative; z-index: 1; }
    .hero-sub strong { color: #a1a1aa; }

    /* BODY */
    .body { padding: 36px 48px 40px; }

    /* INFO BOX */
    .info-box {
      background-color: #18181b;
      border: 1px solid #27272a;
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 20px;
    }
    .info-header {
      background: rgba(20,184,166,.06);
      border-bottom: 1px solid #27272a;
      padding: 11px 20px;
      font-size: 10.5px; font-weight: 700;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: #2dd4bf; font-family: 'Courier New', monospace;
    }
    .info-row { padding: 16px 20px; border-bottom: 1px solid #27272a; }
    .info-row:last-child { border-bottom: none; }
    .info-label { font-size: 11px; font-weight: 600; color: #52525b; text-transform: uppercase; letter-spacing: 0.12em; margin: 0 0 5px; }
    .info-value { font-size: 14.5px; font-weight: 600; color: #a1a1aa; margin: 0; }

    .cluster-tag {
      display: inline-block;
      background: rgba(20,184,166,.08);
      border: 1px solid rgba(20,184,166,.18);
      color: #2dd4bf;
      font-size: 13px; font-weight: 700;
      padding: 3px 12px; border-radius: 999px;
    }

    /* SUCCESS BOX */
    .success-box {
      background-color: #0a1a10;
      border: 1px solid #166534;
      border-left: 3px solid #22c55e;
      border-radius: 8px;
      padding: 14px 18px;
      margin-bottom: 24px;
    }
    .success-box p { font-size: 13px; color: #4ade80; margin: 0; line-height: 1.7; }
    .success-box p strong { color: #86efac; }

    /* CTA */
    .cta-wrap { margin-bottom: 32px; }
    .cta-btn {
      display: inline-block;
      background-color: #0d9488;
      color: #ffffff;
      font-size: 15px; font-weight: 700;
      letter-spacing: 0.02em;
      padding: 14px 30px;
      border-radius: 12px;
      text-decoration: none;
    }

    /* FEATURE LIST */
    .features-label { font-size: 10.5px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #52525b; font-family: 'Courier New', monospace; display: block; margin: 0 0 16px; }

    /* FOOTER */
    .footer { padding: 22px 48px 32px; border-top: 1px solid #27272a; text-align: center; }
    .footer-text  { font-size: 12px; color: #3f3f46; line-height: 1.8; margin: 0 0 6px; }
    .footer-text a { color: #3f3f46; text-decoration: none; }
    .footer-sep   { display: inline-block; margin: 0 8px; color: #27272a; }
    .footer-brand { font-size: 10.5px; color: #27272a; letter-spacing: 0.16em; font-family: 'Courier New', monospace; margin: 14px 0 0; }

    @media only screen and (max-width: 600px) {
      .header, .hero, .body, .footer { padding-left: 28px !important; padding-right: 28px !important; }
      .hero-title { font-size: 20px !important; }
    }
  </style>
</head>
<body>
<div class="wrapper">
  <div class="container">

    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">
      <a href="#" style="text-decoration:none;">
        <span class="logo-hex">⬡</span><span class="logo-name">Nexora</span>
      </a>
      <span class="logo-tag">Where Knowledge Meets Mentorship</span>
    </div>

    <!-- HERO -->
    <div class="hero">
      <div class="hero-badge">&#x25CA;&nbsp; New Cluster</div>
      <h1 class="hero-title">Welcome back, <%= name %>!</h1>
      <p class="hero-sub">
        You've been added to a new cluster:
        <strong><%= clusterName %></strong>.
        Head to your dashboard to get started.
      </p>
    </div>

    <!-- BODY -->
    <div class="body">

      <!-- CLUSTER INFO -->
      <div class="info-box">
        <div class="info-header">&#x25CA;&nbsp; Cluster details</div>
        <div class="info-row">
          <p class="info-label">Cluster</p>
          <p class="info-value"><span class="cluster-tag"><%= clusterName %></span></p>
        </div>
        <div class="info-row">
          <p class="info-label">Your Account Email</p>
          <p class="info-value"><%= email %></p>
        </div>
      </div>

      <!-- SUCCESS -->
      <div class="success-box">
        <p><strong>&#10003;&nbsp; You're all set!</strong> Log in with your existing credentials — the cluster <strong><%= clusterName %></strong> is already visible in your dashboard with all sessions, resources, and tasks.</p>
      </div>

      <!-- CTA -->
      <div class="cta-wrap">
        <a href="<%= loginUrl %>" class="cta-btn">Go to Nexora &rarr;</a>
      </div>

      <!-- WHAT'S WAITING -->
      <span class="features-label">What's waiting for you</span>
      <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
        <% [
          'Sessions with auto-assigned tasks — deadlines visible on your dashboard',
          'A resource library with papers, notes, and study materials',
          'Submit work and receive structured rubric feedback from your teacher',
          'Your progress tracked across attendance, scores, and milestones',
          'AI Study Companion available on every uploaded resource, 24/7',
        ].forEach(function(f) { %>
        <tr><td style="padding-bottom:10px;">
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
            <td width="18" valign="top" style="padding-top:5px;">
              <div style="width:6px;height:6px;background-color:#14b8a6;border-radius:50%;"></div>
            </td>
            <td style="padding-left:10px;">
              <p style="margin:0;font-size:13.5px;color:#71717a;line-height:1.6;"><%= f %></p>
            </td>
          </tr></table>
        </td></tr>
        <% }) %>
      </table>

    </div><!-- /body -->

    <!-- FOOTER -->
    <div class="footer">
      <p class="footer-text">This email was sent because a teacher added you to a cluster on Nexora.<br />If this was unexpected, you can safely ignore this email.</p>
      <p class="footer-text">
        <a href="#">Privacy Policy</a>
        <span class="footer-sep">&bull;</span>
        <a href="#">Terms of Service</a>
        <span class="footer-sep">&bull;</span>
        <a href="#">Help Centre</a>
      </p>
      <p class="footer-brand">NEXORA &nbsp;&bull;&nbsp; WHERE KNOWLEDGE MEETS MENTORSHIP</p>
    </div>

  </div>
</div>
</body>
</html>
