<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exam result published</title>
</head>
<body style="margin:0;background:#09090b;font-family:Arial,sans-serif;color:#e4e4e7;">
  <div style="padding:40px 16px;">
    <div style="max-width:620px;margin:0 auto;background:#111113;border:1px solid #27272a;border-radius:18px;overflow:hidden;">
      <div style="height:4px;background:linear-gradient(90deg,#0d9488,#2dd4bf);"></div>
      <div style="padding:32px 36px;border-bottom:1px solid #27272a;">
        <div style="font-size:20px;font-weight:800;color:#2dd4bf;">Nexora ExamShield</div>
        <p style="margin:8px 0 0;color:#71717a;font-size:12px;">Official assessment result</p>
      </div>
      <div style="padding:32px 36px;">
        <p style="margin:0 0 8px;color:#a1a1aa;font-size:13px;">Hello <strong style="color:#fafafa;"><%= student.name %></strong>,</p>
        <h1 style="margin:0 0 8px;font-size:23px;color:#fafafa;"><%= exam.title %></h1>
        <p style="margin:0 0 24px;color:#71717a;font-size:13px;"><%= exam.cluster?.name || "ExamShield assessment" %></p>

        <table width="100%" cellpadding="0" cellspacing="8" style="margin-bottom:24px;">
          <tr>
            <td style="background:#0a1a17;border:1px solid #134e4a;border-radius:12px;padding:16px;text-align:center;">
              <div style="font-size:24px;font-weight:800;color:#2dd4bf;"><%= attempt.score %>/<%= attempt.totalMarks %></div>
              <div style="font-size:10px;color:#71717a;text-transform:uppercase;">Score</div>
            </td>
            <td style="background:#0a1a17;border:1px solid #134e4a;border-radius:12px;padding:16px;text-align:center;">
              <div style="font-size:24px;font-weight:800;color:#2dd4bf;"><%= attempt.percentage %>%</div>
              <div style="font-size:10px;color:#71717a;text-transform:uppercase;">Percentage</div>
            </td>
            <td style="background:#0a1a17;border:1px solid #134e4a;border-radius:12px;padding:16px;text-align:center;">
              <div style="font-size:24px;font-weight:800;color:#2dd4bf;">#<%= statistics.rank || "-" %></div>
              <div style="font-size:10px;color:#71717a;text-transform:uppercase;">Rank</div>
            </td>
          </tr>
        </table>

        <% if (attempt.suspicious) { %>
          <div style="background:#2a1014;border:1px solid #7f1d1d;border-radius:12px;padding:18px;margin-bottom:22px;">
            <div style="font-size:12px;font-weight:800;color:#fb7185;text-transform:uppercase;">Integrity history</div>
            <p style="font-size:13px;color:#fda4af;line-height:1.6;">Because integrity events were recorded during your attempt, your answer sheet is replaced by the violation history.</p>
            <% violationHistory.forEach(function(event) { %>
              <p style="font-size:12px;color:#d4d4d8;margin:8px 0;"><strong><%= event.type.replaceAll("_", " ") %></strong> · <%= new Date(event.occurredAt).toLocaleString() %></p>
            <% }) %>
          </div>
        <% } else if (answerSheetAvailable && answerSheet) { %>
          <div style="font-size:12px;font-weight:800;color:#2dd4bf;text-transform:uppercase;margin-bottom:12px;">Your answer sheet</div>
          <% answerSheet.forEach(function(answer, index) { %>
            <div style="background:#18181b;border:1px solid #27272a;border-radius:12px;padding:16px;margin-bottom:10px;">
              <div style="font-size:13px;font-weight:700;color:#fafafa;"><%= index + 1 %>. <%= answer.prompt %></div>
              <p style="font-size:12px;color:#a1a1aa;margin:10px 0 0;">Your answer: <strong><%= answer.selectedOption?.text || answer.textAnswer || "Not answered" %></strong></p>
              <p style="font-size:12px;color:#2dd4bf;margin:6px 0 0;">Awarded: <%= answer.awardedMarks %>/<%= answer.marks %></p>
            </div>
          <% }) %>
        <% } else { %>
          <div style="background:#18181b;border:1px solid #27272a;border-radius:12px;padding:16px;margin-bottom:22px;color:#a1a1aa;font-size:13px;">
            Your result is published. The answer sheet has not been released by your teacher.
          </div>
        <% } %>

        <a href="<%= resultUrl %>" style="display:inline-block;background:#0d9488;color:white;text-decoration:none;font-size:13px;font-weight:700;padding:13px 22px;border-radius:10px;">View detailed result</a>
      </div>
      <div style="padding:20px 36px;border-top:1px solid #27272a;color:#52525b;font-size:11px;">This is an official ExamShield result notification from Nexora.</div>
    </div>
  </div>
</body>
</html>
