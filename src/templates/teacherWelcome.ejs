<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="x-apple-disable-message-reformatting" />
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no" />
  <title>Welcome to Nexora — Teacher Account</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; }
    body { margin: 0 !important; padding: 0 !important; width: 100% !important; }

    body { background-color: #09090b; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; }

    .wrapper   { width: 100%; background-color: #09090b; padding: 48px 16px; }
    .container { max-width: 560px; margin: 0 auto; background-color: #111113; border: 1px solid #27272a; border-radius: 16px; overflow: hidden; }

    .top-bar { height: 3px; background: linear-gradient(90deg, transparent 0%, #0d9488 25%, #14b8a6 55%, #2dd4bf 80%, transparent 100%); }

    /* HEADER */
    .header { padding: 36px 48px 28px; text-align: center; border-bottom: 1px solid #27272a; }
    .logo-hex  { display: inline-block; width: 36px; height: 36px; background: rgba(20,184,166,.12); border: 1px solid rgba(20,184,166,.25); border-radius: 9px; font-size: 18px; line-height: 36px; text-align: center; color: #2dd4bf; vertical-align: middle; }
    .logo-name { font-size: 20px; font-weight: 800; letter-spacing: -0.025em; color: #fafafa; vertical-align: middle; margin-left: 10px; }
    .logo-tag  { display: block; margin-top: 7px; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #52525b; font-family: 'Courier New', monospace; }

    /* HERO */
    .hero {
      padding: 36px 48px 30px;
      text-align: center;
      border-bottom: 1px solid #27272a;
      background-color: #0d1117;
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -40px; left: 50%;
      transform: translateX(-50%);
      width: 300px; height: 120px;
      background: radial-gradient(ellipse, rgba(20,184,166,.08) 0%, transparent 70%);
    }
    .hero-badge {
      display: inline-block;
      background: rgba(20,184,166,.1);
      border: 1px solid rgba(20,184,166,.22);
      color: #2dd4bf;
      font-size: 10.5px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      padding: 5px 14px; border-radius: 999px;
      margin-bottom: 18px;
      position: relative; z-index: 1;
      font-family: 'Courier New', monospace;
    }
    .hero-title { font-size: 22px; font-weight: 700; color: #fafafa; margin: 0 0 10px; letter-spacing: -0.02em; position: relative; z-index: 1; }
    .hero-sub   { font-size: 14.5px; color: #71717a; margin: 0; line-height: 1.75; position: relative; z-index: 1; }
    .hero-sub strong { color: #a1a1aa; }

    /* BODY */
    .body { padding: 36px 48px 40px; }

    /* CREDENTIALS BOX */
    .creds-box {
      background-color: #18181b;
      border: 1px solid #27272a;
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 20px;
    }
    .creds-header {
      background: rgba(20,184,166,.06);
      border-bottom: 1px solid #27272a;
      padding: 11px 20px;
      font-size: 10.5px; font-weight: 700;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: #2dd4bf; font-family: 'Courier New', monospace;
    }
    .creds-row { padding: 16px 20px; border-bottom: 1px solid #27272a; }
    .creds-row:last-child { border-bottom: none; }
    .creds-label { font-size: 11px; font-weight: 600; color: #52525b; text-transform: uppercase; letter-spacing: 0.12em; margin: 0 0 5px; }
    .creds-value { font-size: 14.5px; font-weight: 600; color: #a1a1aa; margin: 0; }
    .creds-pw {
      display: inline-block;
      background: rgba(20,184,166,.08);
      border: 1px solid rgba(20,184,166,.2);
      color: #2dd4bf;
      font-family: 'Courier New', monospace;
      font-size: 15px; font-weight: 700;
      letter-spacing: 0.08em;
      padding: 5px 14px; border-radius: 8px;
      margin-top: 4px;
    }

    /* WARNING */
    .warning {
      background-color: #1a1209;
      border: 1px solid #3a2a10;
      border-left: 3px solid #f59e0b;
      border-radius: 8px;
      padding: 14px 18px;
      margin-bottom: 24px;
    }
    .warning p { font-size: 13px; color: #78716c; margin: 0; line-height: 1.7; }
    .warning p strong { color: #f59e0b; }

    /* UPGRADE NOTICE */
    .upgrade-notice {
      background-color: #18181b;
      border: 1px solid #27272a;
      border-radius: 8px;
      padding: 14px 18px;
      margin-bottom: 24px;
    }
    .upgrade-notice p { font-size: 13px; color: #71717a; margin: 0; line-height: 1.7; }

    /* CTA BUTTON */
    .cta-wrap { margin-bottom: 32px; }
    .cta-btn {
      display: inline-block;
      background-color: #0d9488;
      color: #ffffff;
      font-size: 15px; font-weight: 700;
      letter-spacing: 0.02em;
      padding: 14px 30px;
      border-radius: 12px;
      text-decoration: none;
    }

    /* FEATURES */
    .features-label { font-size: 10.5px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #52525b; font-family: 'Courier New', monospace; display: block; margin: 0 0 16px; }
    .feature-item   { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 12px; }
    .feature-dot    { width: 6px; height: 6px; background-color: #14b8a6; border-radius: 50%; margin-top: 6px; flex-shrink: 0; }
    .feature-text   { font-size: 13.5px; color: #71717a; line-height: 1.6; }
    .feature-text strong { color: #a1a1aa; }

    /* FOOTER */
    .footer { padding: 22px 48px 32px; border-top: 1px solid #27272a; text-align: center; }
    .footer-text  { font-size: 12px; color: #3f3f46; line-height: 1.8; margin: 0 0 6px; }
    .footer-text a { color: #3f3f46; text-decoration: none; }
    .footer-sep   { display: inline-block; margin: 0 8px; color: #27272a; }
    .footer-brand { font-size: 10.5px; color: #27272a; letter-spacing: 0.16em; font-family: 'Courier New', monospace; margin: 14px 0 0; }

    @media only screen and (max-width: 600px) {
      .header, .hero, .body, .footer { padding-left: 28px !important; padding-right: 28px !important; }
      .hero-title { font-size: 20px !important; }
    }
  </style>
</head>
<body>
<div class="wrapper">
  <div class="container">

    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">
      <a href="#" style="text-decoration:none;">
        <span class="logo-hex">⬡</span><span class="logo-name">Nexora</span>
      </a>
      <span class="logo-tag">Where Knowledge Meets Mentorship</span>
    </div>

    <!-- HERO -->
    <div class="hero">
      <div class="hero-badge">&#x25CA;&nbsp; Teacher Account</div>
      <h1 class="hero-title">Welcome aboard, <%= name %></h1>
      <p class="hero-sub">
        You have been registered as a <strong>Teacher</strong> on Nexora.
        You now have access to create clusters, schedule sessions, and manage your members.
      </p>
    </div>

    <!-- BODY -->
    <div class="body">

      <% if (typeof password !== "undefined" && password) { %>

      <!-- CREDENTIALS -->
      <div class="creds-box">
        <div class="creds-header">&#x1F511;&nbsp; Your login credentials</div>
        <div class="creds-row">
          <p class="creds-label">Email</p>
          <p class="creds-value"><%= email %></p>
        </div>
        <div class="creds-row">
          <p class="creds-label">Temporary Password</p>
          <p style="margin:0;"><span class="creds-pw"><%= password %></span></p>
        </div>
      </div>

      <!-- WARNING -->
      <div class="warning">
        <p><strong>&#9888;&nbsp; Action required:</strong> You must change your password on first login.
        This temporary password will expire after <strong style="color:#f59e0b;">7 days</strong>.</p>
      </div>

      <% } else { %>

      <!-- UPGRADE NOTICE -->
      <div class="upgrade-notice">
        <p>Since you already have a Nexora account, you can log in with your existing credentials.
        Your account role has been <strong style="color:#2dd4bf;">upgraded to Teacher</strong>.</p>
      </div>

      <% } %>

      <!-- CTA -->
      <div class="cta-wrap">
        <a href="<%= loginUrl %>" class="cta-btn">Login to Nexora &rarr;</a>
      </div>

      <!-- WHAT YOU CAN DO -->
      <span class="features-label">What you can do as a Teacher</span>
      <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
        <% [
          ['Create clusters and invite members by email — credentials auto-generated', ''],
          ['Schedule sessions and auto-assign tasks to all active members', ''],
          ['Upload resources with optional comprehension quizzes', ''],
          ['Review submissions with custom rubrics and grading criteria', ''],
          ['Track each member\'s progress on a real-time radar-chart dashboard', ''],
        ].forEach(function(f) { %>
        <tr><td style="padding-bottom:10px;">
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation"><tr>
            <td width="18" valign="top" style="padding-top:5px;">
              <div style="width:6px;height:6px;background-color:#14b8a6;border-radius:50%;"></div>
            </td>
            <td style="padding-left:10px;">
              <p style="margin:0;font-size:13.5px;color:#71717a;line-height:1.6;"><%= f[0] %></p>
            </td>
          </tr></table>
        </td></tr>
        <% }) %>
      </table>

    </div><!-- /body -->

    <!-- FOOTER -->
    <div class="footer">
      <p class="footer-text">This email was sent because an administrator added you as a Teacher on Nexora.<br />If this was unexpected, please contact our support team.</p>
      <p class="footer-text">
        <a href="#">Privacy Policy</a>
        <span class="footer-sep">&bull;</span>
        <a href="#">Terms of Service</a>
        <span class="footer-sep">&bull;</span>
        <a href="#">Help Centre</a>
      </p>
      <p class="footer-brand">NEXORA &nbsp;&bull;&nbsp; WHERE KNOWLEDGE MEETS MENTORSHIP</p>
    </div>

  </div>
</div>
</body>
</html>
