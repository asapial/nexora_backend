<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Connecting with Google — Nexora</title>
  <style>
    /* ── RESET ───────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── DESIGN TOKENS — matches Nexora's teal system ─ */
    :root {
      --bg:          #09090b;          /* zinc-950 */
      --card-bg:     #111113;          /* zinc-900 */
      --card-border: rgba(255,255,255,.07);
      --teal-500:    #14b8a6;
      --teal-600:    #0d9488;
      --teal-400:    #2dd4bf;
      --teal-300:    #5eead4;
      --teal-dim:    rgba(20,184,166,.1);
      --teal-glow:   rgba(20,184,166,.15);
      --red-500:     #ef4444;
      --red-bg:      rgba(239,68,68,.08);
      --red-border:  rgba(239,68,68,.2);
      --text-1:      #fafafa;          /* zinc-50  */
      --text-2:      #a1a1aa;          /* zinc-400 */
      --text-3:      #52525b;          /* zinc-600 */
      --rule:        rgba(255,255,255,.06);
    }

    html, body {
      height: 100%;
      background-color: var(--bg);
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI',
                   system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    /* ── PAGE SHELL ──────────────────────────────────── */
    .page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
      position: relative;
      overflow: hidden;

      /* radial teal glow from centre-top */
      background:
        radial-gradient(ellipse 70% 45% at 50% 0%, rgba(20,184,166,.09) 0%, transparent 70%),
        #09090b;
    }

    /* subtle grid overlay */
    .page::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(20,184,166,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(20,184,166,.025) 1px, transparent 1px);
      background-size: 52px 52px;
      pointer-events: none;
      z-index: 0;
    }

    /* floating orbs */
    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(40px);
      pointer-events: none;
      z-index: 0;
    }
    .orb-1 {
      width: 400px; height: 400px;
      top: -130px; left: -100px;
      background: radial-gradient(circle, rgba(20,184,166,.09) 0%, transparent 65%);
      animation: orb-drift 14s ease-in-out infinite;
    }
    .orb-2 {
      width: 300px; height: 300px;
      bottom: -80px; right: -70px;
      background: radial-gradient(circle, rgba(20,184,166,.06) 0%, transparent 65%);
      animation: orb-drift 10s ease-in-out infinite 4s;
    }

    @keyframes orb-drift {
      0%,100% { transform: translate(0,0) scale(1); }
      50%      { transform: translate(-16px,16px) scale(1.05); }
    }

    /* corner SVG decorations */
    .corner-svg {
      position: fixed;
      pointer-events: none;
      opacity: .055;
      z-index: 0;
    }
    .corner-svg.tl { top: 0; left: 0; }
    .corner-svg.br { bottom: 0; right: 0; transform: rotate(180deg); }

    /* ── CARD ─────────────────────────────────────────── */
    .card {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 432px;
      background: var(--card-bg);
      border-radius: 24px;
      border: 1px solid var(--card-border);
      overflow: hidden;
      box-shadow:
        0 0 0 1px rgba(20,184,166,.06),
        0 24px 64px -12px rgba(0,0,0,.55),
        0 8px 24px -4px rgba(0,0,0,.3);
      /* entrance animation */
      animation: card-in .6s cubic-bezier(.16,1,.3,1) both;
    }

    @keyframes card-in {
      from { opacity: 0; transform: translateY(22px) scale(.97); }
      to   { opacity: 1; transform: translateY(0)   scale(1);    }
    }

    /* teal top-accent rule */
    .card-bar {
      height: 2px;
      background: linear-gradient(90deg,
        transparent   0%,
        var(--teal-600) 30%,
        var(--teal-400) 55%,
        var(--teal-300) 75%,
        transparent   100%
      );
    }

    .card-body {
      padding: 44px 40px 40px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    /* ── NEXORA LOGO ──────────────────────────────────── */
    .logo {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      margin-bottom: 36px;
    }

    .logo-hex {
      width: 34px; height: 34px;
      border-radius: 9px;
      background: var(--teal-dim);
      border: 1px solid rgba(20,184,166,.25);
      display: flex; align-items: center; justify-content: center;
      color: var(--teal-400);
      font-size: 16px;
      line-height: 1;
      flex-shrink: 0;
    }

    .logo-text {
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -.025em;
      color: var(--text-1);
    }

    /* ── ICON STACK ───────────────────────────────────── */
    .icon-stack {
      position: relative;
      width: 80px; height: 80px;
      margin-bottom: 28px;
    }

    /* outer pulse ring */
    .icon-stack::before {
      content: '';
      position: absolute;
      inset: -10px;
      border-radius: 50%;
      border: 1.5px solid rgba(20,184,166,.22);
      animation: ring-pulse 2.4s ease-in-out infinite;
    }
    /* mid pulse ring */
    .icon-stack::after {
      content: '';
      position: absolute;
      inset: -20px;
      border-radius: 50%;
      border: 1px solid rgba(20,184,166,.1);
      animation: ring-pulse 2.4s ease-in-out infinite .4s;
    }

    @keyframes ring-pulse {
      0%,100% { transform: scale(1);    opacity: 1;   }
      50%      { transform: scale(1.09); opacity: 0.3; }
    }

    .icon-circle {
      width: 80px; height: 80px;
      border-radius: 50%;
      background: rgba(20,184,166,.08);
      border: 1.5px solid rgba(20,184,166,.2);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      /* inner shimmer */
      background: linear-gradient(135deg,
        rgba(20,184,166,.12) 0%,
        rgba(20,184,166,.04) 100%
      );
    }

    .icon-circle svg { width: 38px; height: 38px; }

    /* ── CARD HEADING ─────────────────────────────────── */
    .card-title {
      font-size: 20px;
      font-weight: 800;
      color: var(--text-1);
      letter-spacing: -.02em;
      margin-bottom: 8px;
    }

    .card-sub {
      font-size: 13.5px;
      color: var(--text-2);
      line-height: 1.75;
      max-width: 290px;
      margin: 0 auto 32px;
    }

    /* ── PROGRESS BAR ─────────────────────────────────── */
    .progress-wrap {
      width: 100%;
      height: 3px;
      background: rgba(255,255,255,.06);
      border-radius: 999px;
      overflow: hidden;
      margin-bottom: 14px;
    }

    .progress-bar {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg,
        var(--teal-600) 0%,
        var(--teal-400) 55%,
        var(--teal-300) 100%
      );
      border-radius: 999px;
      animation: progress-fill 2.8s cubic-bezier(.4,0,.2,1) forwards;
    }

    @keyframes progress-fill {
      0%   { width: 0%;  }
      55%  { width: 72%; }
      80%  { width: 86%; }
      100% { width: 94%; }
    }

    /* ── STATUS ROW ───────────────────────────────────── */
    .status-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      height: 20px;
      font-size: 12.5px;
      color: var(--text-3);
      letter-spacing: .02em;
    }

    /* teal bouncing dots */
    .dot {
      width: 4px; height: 4px;
      background: var(--teal-500);
      border-radius: 50%;
      opacity: .4;
      animation: dot-bounce 1.3s ease-in-out infinite;
    }
    .dot:nth-child(2) { animation-delay: .18s; }
    .dot:nth-child(3) { animation-delay: .36s; }

    @keyframes dot-bounce {
      0%,80%,100% { transform: scale(1);   opacity: .35; }
      40%          { transform: scale(1.5); opacity: 1;   }
    }

    /* ── SECURE BADGE ─────────────────────────────────── */
    .secure-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 28px;
      padding: 6px 14px;
      background: rgba(20,184,166,.07);
      border: 1px solid rgba(20,184,166,.18);
      border-radius: 999px;
      font-size: 11.5px;
      font-weight: 600;
      color: var(--teal-400);
    }

    .secure-badge svg {
      width: 12px; height: 12px;
      flex-shrink: 0;
    }

    /* ── ERROR CARD ───────────────────────────────────── */
    .error-card {
      display: none;
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 432px;
      background: var(--card-bg);
      border-radius: 24px;
      border: 1px solid var(--red-border);
      overflow: hidden;
      box-shadow:
        0 0 0 1px rgba(239,68,68,.06),
        0 24px 64px -12px rgba(0,0,0,.55);
      animation: card-in .5s cubic-bezier(.16,1,.3,1) both;
    }

    .error-bar {
      height: 2px;
      background: linear-gradient(90deg,
        transparent 0%,
        var(--red-500) 30%,
        #f97316 70%,
        transparent 100%
      );
    }

    .error-body {
      padding: 44px 40px 40px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .error-icon {
      width: 72px; height: 72px;
      border-radius: 50%;
      background: var(--red-bg);
      border: 1px solid var(--red-border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      margin-bottom: 22px;
    }

    .error-title {
      font-size: 19px;
      font-weight: 800;
      color: var(--text-1);
      letter-spacing: -.02em;
      margin-bottom: 10px;
    }

    .error-msg {
      font-size: 13.5px;
      color: var(--text-2);
      line-height: 1.75;
      margin-bottom: 24px;
      max-width: 300px;
    }

    .error-detail {
      display: none;
      font-size: 11.5px;
      font-family: 'Courier New', monospace;
      color: var(--red-500);
      background: var(--red-bg);
      border: 1px solid var(--red-border);
      border-radius: 10px;
      padding: 10px 14px;
      width: 100%;
      text-align: left;
      margin-bottom: 26px;
      word-break: break-all;
      line-height: 1.6;
    }

    /* ── RETRY BUTTON ─────────────────────────────────── */
    .retry-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 28px;
      background: var(--teal-600);
      color: #ffffff;
      font-size: 14px;
      font-weight: 700;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      text-decoration: none;
      transition: background .2s, transform .15s;
      box-shadow: 0 6px 22px rgba(13,148,136,.28);
    }
    .retry-btn:hover  { background: #0f766e; transform: scale(1.02); }
    .retry-btn:active { transform: scale(.98); }

    .retry-btn svg { width: 14px; height: 14px; flex-shrink: 0; }

    /* ── FOOTER ───────────────────────────────────────── */
    .page-footer {
      position: relative;
      z-index: 10;
      margin-top: 22px;
      font-size: 11.5px;
      color: var(--text-3);
      text-align: center;
    }

    /* ── RESPONSIVE ───────────────────────────────────── */
    @media (max-width: 480px) {
      .card-body, .error-body { padding: 36px 28px 32px; }
      .card-title, .error-title { font-size: 18px; }
    }
  </style>
</head>
<body>

  <div class="page">

    <!-- Corner arc decorations -->
    <svg class="corner-svg tl" width="180" height="180" viewBox="0 0 180 180" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="0" cy="0" r="140" stroke="#14b8a6" stroke-width=".7"/>
      <circle cx="0" cy="0" r="90"  stroke="#14b8a6" stroke-width=".7"/>
      <circle cx="0" cy="0" r="45"  stroke="#14b8a6" stroke-width=".7"/>
      <line x1="0" y1="90"  x2="90"  y2="0" stroke="#14b8a6" stroke-width=".5"/>
      <line x1="0" y1="140" x2="140" y2="0" stroke="#14b8a6" stroke-width=".4"/>
    </svg>
    <svg class="corner-svg br" width="180" height="180" viewBox="0 0 180 180" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="0" cy="0" r="140" stroke="#14b8a6" stroke-width=".7"/>
      <circle cx="0" cy="0" r="90"  stroke="#14b8a6" stroke-width=".7"/>
      <circle cx="0" cy="0" r="45"  stroke="#14b8a6" stroke-width=".7"/>
    </svg>

    <!-- Background orbs -->
    <div class="orb orb-1" aria-hidden="true"></div>
    <div class="orb orb-2" aria-hidden="true"></div>

    <!-- ══════════════════════════════════════════════════
         LOADING CARD
    ══════════════════════════════════════════════════ -->
    <div class="card" id="loadingCard" role="status" aria-live="polite" aria-label="Connecting with Google">
      <div class="card-bar"></div>
      <div class="card-body">

        <!-- Nexora logo -->
        <a class="logo" href="/" aria-label="Nexora home">
          <div class="logo-hex" aria-hidden="true">⬡</div>
          <span class="logo-text">Nexora</span>
        </a>

        <!-- Google icon with orbital rings -->
        <div class="icon-stack" aria-hidden="true">
          <div class="icon-circle">
            <!-- Official Google G mark -->
            <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Google">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.08 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-3.59-13.46-8.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
              <path fill="none" d="M0 0h48v48H0z"/>
            </svg>
          </div>
        </div>

        <h1 class="card-title">Connecting with Google</h1>
        <p class="card-sub">
          Please wait while we securely redirect you to
          Google to complete sign-in.
        </p>

        <!-- Progress bar -->
        <div class="progress-wrap" role="progressbar" aria-label="Connection progress">
          <div class="progress-bar" id="progressBar"></div>
        </div>

        <!-- Status dots + message -->
        <div class="status-row">
          <span class="dot" aria-hidden="true"></span>
          <span class="dot" aria-hidden="true"></span>
          <span class="dot" aria-hidden="true"></span>
          <span id="statusMsg">Initiating secure connection</span>
        </div>

        <!-- OAuth badge -->
        <div class="secure-badge" aria-label="Secured with OAuth 2.0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
          Secured with OAuth 2.0
        </div>

      </div>
    </div>

    <!-- ══════════════════════════════════════════════════
         ERROR CARD
    ══════════════════════════════════════════════════ -->
    <div class="error-card" id="errorCard" role="alert" aria-label="Connection failed">
      <div class="error-bar"></div>
      <div class="error-body">

        <!-- Nexora logo -->
        <a class="logo" href="/" aria-label="Nexora home">
          <div class="logo-hex" aria-hidden="true">⬡</div>
          <span class="logo-text">Nexora</span>
        </a>

        <div class="error-icon" aria-hidden="true">⚠</div>

        <h1 class="error-title">Redirect Failed</h1>
        <p class="error-msg" id="errorMsg">
          Something went wrong while connecting to Google.
          Please try again — your account has not been affected.
        </p>

        <!-- Technical error detail (shown only when available) -->
        <pre class="error-detail" id="errorDetail"></pre>

        <button class="retry-btn" onclick="startAuth()" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="23 4 23 10 17 10"/>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
          </svg>
          Try Again
        </button>

      </div>
    </div>

    <p class="page-footer">
      &copy; <span id="yr"></span> Nexora Technologies. All rights reserved.
    </p>

  </div><!-- .page -->

  <script>
    /* ── Year ─────────────────────────────────────────── */
    document.getElementById('yr').textContent = new Date().getFullYear();

    /* ── Status messages ──────────────────────────────── */
    const MESSAGES = [
      'Initiating secure connection',
      'Contacting Google servers',
      'Preparing your redirect',
      'Almost there',
    ];
    let msgIdx = 0;
    let msgTimer = null;

    function cycleMessages() {
      msgTimer = setInterval(function () {
        msgIdx = (msgIdx + 1) % MESSAGES.length;
        const el = document.getElementById('statusMsg');
        if (el) {
          el.style.opacity = '0';
          el.style.transition = 'opacity .25s';
          setTimeout(function () {
            el.textContent = MESSAGES[msgIdx];
            el.style.opacity = '1';
          }, 260);
        }
      }, 950);
    }

    /* ── Show error state ─────────────────────────────── */
    function showError(message, detail) {
      clearInterval(msgTimer);

      document.getElementById('loadingCard').style.display = 'none';

      const errorCard   = document.getElementById('errorCard');
      const errorMsg    = document.getElementById('errorMsg');
      const errorDetail = document.getElementById('errorDetail');

      errorCard.style.display = 'block';

      if (message) {
        errorMsg.textContent = message;
      }

      if (detail) {
        errorDetail.style.display = 'block';
        errorDetail.textContent   = detail;
      }
    }

    /* ── Main auth flow ───────────────────────────────── */
    async function startAuth() {
      /* reset UI if retrying */
      clearInterval(msgTimer);
      msgIdx = 0;

      document.getElementById('errorCard').style.display   = 'none';
      document.getElementById('loadingCard').style.display = 'block';

      const statusEl = document.getElementById('statusMsg');
      if (statusEl) statusEl.textContent = MESSAGES[0];

      /* restart progress bar animation by cloning the element */
      const oldBar = document.getElementById('progressBar');
      if (oldBar) {
        const newBar = oldBar.cloneNode(true);
        oldBar.parentNode.replaceChild(newBar, oldBar);
      }

      cycleMessages();

      try {
        const response = await fetch(
          // '<%= betterAuthUrl %>/api/auth/sign-in/social',
          '/api/auth/sign-in/social',
          {
            method:      'POST',
            headers:     { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              provider:    'google',
              callbackURL: '<%= callbackURL %>',
            }),
          }
        );

        const data = await response.json();

        if (data && data.url) {
          /* show final status then redirect */
          clearInterval(msgTimer);
          const el = document.getElementById('statusMsg');
          if (el) el.textContent = 'Redirecting to Google';
          setTimeout(function () {
            window.location.href = data.url;
          }, 320);
        } else {
          showError(
            'Google sign-in is temporarily unavailable. Please try again in a moment.',
            data.error || data.message || null
          );
        }

      } catch (err) {
        showError(
          'A network error occurred while connecting to Google. Check your connection and try again.',
          err && err.message ? err.message : null
        );
      }
    }

    /* ── Boot ─────────────────────────────────────────── */
    cycleMessages();
    startAuth();
  </script>

</body>
</html>
